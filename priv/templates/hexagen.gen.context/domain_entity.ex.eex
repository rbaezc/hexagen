defmodule <%= base_module %>.Domain.Entities.<%= schema_alias %> do
  @moduledoc """
  The <%= schema_alias %> domain entity.
  """

  defstruct [:id | <%= inspect(Enum.map(schema.attrs, fn {k, _} -> k end)) %>]

  @type t :: %__MODULE__{
    id: term(),
<%= for {k, _} <- schema.attrs do %>    <%= k %>: term(),
<% end %>  }
end
